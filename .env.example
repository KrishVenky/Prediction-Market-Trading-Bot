# ── Groq (PRIMARY — free tier, high RPM, most reliable for demos) ────────────
# Sign up at https://console.groq.com — get API key instantly, no credit card
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Gemini (secondary fallback) ────────────────────────────────────────
# Get yours at https://aistudio.google.com/app/apikey
# WARNING: free-tier daily quota exhausts after ~5 pipeline runs
GOOGLE_API_KEY=your_google_api_key_here

# ── LangSmith tracing (optional — useful for demos to show the trace) ─────────
# Sign up at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=polysignal

# ── Ollama (optional — local LLM, zero cost) ──────────────────────────────────
# Run: ollama pull qwen2.5:14b   then   ollama serve
# Pipeline falls back to Groq automatically if Ollama is not running
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
