# ── Gemini Flash (primary LLM) ────────────────────────────────────────────────
# Get yours at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── LangSmith tracing (free tier, highly recommended for the demo) ────────────
# Sign up at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=polysignal

# ── Ollama (local — for CrewAI debate agents) ─────────────────────────────────
# Run: ollama pull qwen2.5:14b   then   ollama serve
# Falls back to Gemini Flash automatically if Ollama is not running
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
